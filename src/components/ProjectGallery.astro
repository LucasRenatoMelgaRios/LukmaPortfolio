---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryItem {
  src: ImageMetadata;
  alt: string;
  label: string;
}

interface Props {
  project: string;
  items: GalleryItem[];
  accent?: 'coral' | 'lime';
}

const { project, items, accent = 'coral' } = Astro.props;
const sticker = accent === 'lime' ? 'bg-lime text-ink' : 'bg-coral text-white';
---
<section class="mt-14" aria-labelledby={`galeria-${project.toLowerCase()}`}>
  <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
    <div>
      <p class="hand text-2xl text-coral">capturas del producto</p>
      <h4 id={`galeria-${project.toLowerCase()}`} class="display text-3xl md:text-4xl">{project}, por dentro.</h4>
    </div>
    <span class={`-rotate-2 rounded-full px-3 py-1.5 text-xs font-bold ${sticker}`}>4 vistas reales</span>
  </div>
  <div class="-mx-5 flex snap-x snap-mandatory gap-4 overflow-x-auto px-5 pb-5 md:mx-0 md:grid md:grid-cols-2 md:overflow-visible md:px-0" role="list">
    {items.map((item, index) => (
      <figure class={`paper-card rough-border hover-lift group relative min-w-[88%] snap-center overflow-hidden p-2 md:min-w-0 ${index % 2 ? 'md:rotate-[.5deg]' : 'md:-rotate-[.4deg]'}`} role="listitem">
        <a href={item.src.src} target="_blank" rel="noreferrer" class="focus-ring block overflow-hidden rounded-[12px_8px_15px_10px]" aria-label={`Abrir captura: ${item.label}`}>
          <Image
            src={item.src}
            alt={item.alt}
            widths={[480, 800, 1200]}
            sizes="(max-width: 767px) 88vw, 540px"
            loading="lazy"
            class="aspect-[16/9] h-full w-full object-cover object-top transition duration-500 group-hover:scale-[1.015]"
          />
        </a>
        <figcaption class="flex items-center justify-between gap-3 px-2 py-3">
          <span class="text-sm font-bold"><span class="mr-2 hand text-lg text-coral">0{index + 1}</span>{item.label}</span>
          <span class="text-xs text-ink-soft" aria-hidden="true">ampliar ↗</span>
        </figcaption>
      </figure>
    ))}
  </div>
  <p class="mt-1 text-center text-xs text-ink-soft md:hidden">Desliza para explorar las capturas →</p>
</section>
