---
<span class="inline-flex items-center gap-2 rounded-full border border-ink/25 bg-white px-3 py-1.5 text-xs font-bold shadow-[2px_2px_0_rgba(23,63,95,.06)]">
  {icon ? <img src={icon} alt="" width="17" height="17" loading="lazy" decoding="async" class="size-4 object-contain" aria-hidden="true" /> : <span class="flex size-4 items-center justify-center rounded bg-paper-deep text-[9px]" aria-hidden="true">&lt;/&gt;</span>}
  {name}
</span>
